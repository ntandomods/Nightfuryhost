# Server Config
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nightfury_hosting
DATABASE_URL=mongodb://localhost:27017/nightfury_hosting

# Stripe Payment (Coin System)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@nightfuryhost.com

# OAuth Credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Render.com Config
RENDER_API_KEY=your_render_api_key
RENDER_ENVIRONMENT=production

# WhatsApp Config
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# Admin
ADMIN_EMAIL=admin@nightfuryhost.com
ADMIN_PASSWORD=change_this_in_production

# Security
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
SESSION_SECRET=your_session_secret_key
