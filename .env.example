# Server
PORT=5000
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Render.com
RENDER_API_KEY=your_render_api_key
# REQUIRED: your Render owner/team ID — get it from:
#   curl -s https://api.render.com/v1/owners -H "Authorization: Bearer <RENDER_API_KEY>" | python3 -c "import json,sys;d=json.load(sys.stdin);print(d[0]['owner']['id'])"
RENDER_OWNER_ID=tea-xxxxxxxxxxxxxxxx

# The hosting platform automatically deploys https://github.com/ntando-deeev/NightFuryBot
# as a background_worker on Render. No extra config needed here — users supply their
# SESSION_ID and OWNER_NUMBER through the dashboard when creating a host.

# Email (optional — leave blank to disable email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Admin seed account
ADMIN_EMAIL=admin@nightfuryhost.com
ADMIN_PASSWORD=change_this_secure_password

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Session
SESSION_SECRET=your_session_secret_key
